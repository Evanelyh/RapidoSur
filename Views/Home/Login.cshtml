@{
    ViewData["Title"] = "Acceso Personal";
    var conductores = ViewBag.Conductores as List<RapidoSur.Models.Conductor> ?? new();
}

<div style="max-width: 460px; margin: 5rem auto; padding: 0 1.5rem;">
    <div class="glass-card">
        <div style="text-align: center; margin-bottom: 2rem;">
            <!-- Icono Logístico SVG -->
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-bottom: 0.75rem;"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
            <h2>Acceso al Sistema</h2>
            <p style="color: var(--text-muted); font-size: 0.85rem; margin-top: 0.25rem;">Rápido Sur S.R.L. - Control Logístico</p>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div style="background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.3); border-radius: var(--radius-md); padding: 0.75rem 1rem; color: var(--danger); font-size: 0.85rem; margin-bottom: 1.5rem;" asp-validation-summary="All">
            </div>
        }

        <!-- Selector de Tipo de Acceso -->
        <div style="display: flex; gap: 0.5rem; background: rgba(15, 23, 42, 0.4); padding: 0.35rem; border-radius: var(--radius-md); margin-bottom: 1.5rem;">
            <button type="button" id="btnTabOperador" class="btn btn-secondary" style="flex: 1; padding: 0.6rem; font-size: 0.85rem; background: var(--primary);" onclick="switchTab('Operador')">
                Operador / Admin
            </button>
            <button type="button" id="btnTabConductor" class="btn btn-secondary" style="flex: 1; padding: 0.6rem; font-size: 0.85rem; background: transparent; border: none;" onclick="switchTab('Conductor')">
                Conductor
            </button>
        </div>

        <form method="post" action="@Url.Action("Login", "Home")">
            <!-- Campo oculto para tipo de acceso -->
            <input type="hidden" id="userType" name="userType" value="Operador" />

            <!-- FORMULARIO OPERADOR -->
            <div id="formOperador">
                <div class="form-group">
                    <label for="usuario" class="form-label">Nombre de Usuario:</label>
                    <input type="text" id="usuario" name="usuario" class="form-control" placeholder="Ej. lcontreras" />
                </div>
                <div class="form-group" style="margin-bottom: 1.5rem;">
                    <label for="clave" class="form-label">Contraseña:</label>
                    <input type="password" id="clave" name="clave" class="form-control" placeholder="••••••••" />
                </div>
            </div>

            <!-- FORMULARIO CONDUCTOR (Simulado rápido para universidad) -->
            <div id="formConductor" style="display: none;">
                <div class="form-group" style="margin-bottom: 1.5rem;">
                    <label for="idConductor" class="form-label">Seleccione su Nombre:</label>
                    <select id="idConductor" name="idConductor" class="form-control">
                        <option value="">-- Seleccionar Chofer --</option>
                        @foreach (var c in conductores)
                        {
                            <option value="@c.IdConductor">@c.Nombre @c.Apellido (@c.NumLicencia)</option>
                        }
                    </select>
                </div>
            </div>

            <button type="submit" class="btn btn-primary" style="width: 100%; height: 46px;">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"></path><polyline points="10 17 15 12 10 7"></polyline><line x1="15" y1="12" x2="3" y2="12"></line></svg>
                Ingresar al Sistema
            </button>
        </form>

        <div style="text-align: center; margin-top: 1.5rem; border-top: 1px solid var(--border); padding-top: 1rem;">
            <p style="color: var(--text-muted); font-size: 0.8rem;">
                <strong>Credenciales Demo Operador:</strong> usuario: <code>lcontreras</code> | clave: <code>lcontreras123</code>
            </p>
        </div>
    </div>
</div>

<script>
    function switchTab(type) {
        document.getElementById('userType').value = type;
        
        const btnTabOperador = document.getElementById('btnTabOperador');
        const btnTabConductor = document.getElementById('btnTabConductor');
        
        const formOperador = document.getElementById('formOperador');
        const formConductor = document.getElementById('formConductor');
        
        if (type === 'Operador') {
            btnTabOperador.style.background = 'var(--primary)';
            btnTabOperador.style.border = 'none';
            btnTabConductor.style.background = 'transparent';
            btnTabConductor.style.border = 'none';
            
            formOperador.style.display = 'block';
            formConductor.style.display = 'none';
            
            document.getElementById('usuario').required = true;
            document.getElementById('clave').required = true;
            document.getElementById('idConductor').required = false;
        } else {
            btnTabOperador.style.background = 'transparent';
            btnTabOperador.style.border = 'none';
            btnTabConductor.style.background = 'var(--primary)';
            btnTabConductor.style.border = 'none';
            
            formOperador.style.display = 'none';
            formConductor.style.display = 'block';
            
            document.getElementById('usuario').required = false;
            document.getElementById('clave').required = false;
            document.getElementById('idConductor').required = true;
        }
    }
    
    // Ejecutar al cargar para inicializar campos requeridos
    switchTab('Operador');
</script>
