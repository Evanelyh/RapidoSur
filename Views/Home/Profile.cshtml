@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
@{
    ViewData["Title"] = "Mi Perfil";
    var session = HttpContextAccessor.HttpContext?.Session;
    var userName = session?.GetString("UserName") ?? "";
    var userEmail = session?.GetString("UserEmail") ?? "";
    var userRole = session?.GetString("UserRole") ?? "";
    var userUsername = session?.GetString("Username") ?? "";
    
    // Dividir nombre y apellido tentativamente para el formulario
    var parts = userName.Split(' ');
    var nombre = parts.Length > 0 ? parts[0] : "";
    var apellido = parts.Length > 1 ? string.Join(" ", parts.Skip(1)) : "";
}

<div class="header-navbar">
    <div>
        <h1 class="page-title">Mi Perfil</h1>
        <p class="page-subtitle">Gestione sus datos de contacto y credenciales de acceso al sistema.</p>
    </div>
</div>

<div class="form-row">
    <!-- Bloque Lateral Resumen Perfil -->
    <div style="flex: 1; max-width: 320px;">
        <div class="glass-card" style="text-align: center; padding: 2.5rem 1.5rem;">
            <div class="user-avatar" style="width: 80px; height: 80px; font-size: 2.5rem; margin: 0 auto 1.5rem auto;">
                @userName.Substring(0, 1).ToUpper()
            </div>
            <h2 style="font-size: 1.35rem; margin-bottom: 0.25rem;">@userName</h2>
            <span class="badge" style="background: rgba(59, 130, 246, 0.15); color: var(--primary); margin-bottom: 1.5rem;">
                @userRole
            </span>
            
            <div style="text-align: left; border-top: 1px solid var(--border); padding-top: 1.5rem; font-size: 0.85rem; color: var(--text-muted);">
                <div style="margin-bottom: 0.75rem;">
                    <span style="display: block; font-weight: 600; color: #fff;">Nombre de Usuario:</span>
                    @@@userUsername
                </div>
                <div>
                    <span style="display: block; font-weight: 600; color: #fff;">Correo de Contacto:</span>
                    @userEmail
                </div>
            </div>
        </div>
    </div>

    <!-- Formulario Principal -->
    <div style="flex: 2;">
        <div class="glass-card">
            <h3 style="margin-bottom: 1.5rem; padding-bottom: 0.5rem; border-bottom: 1px solid var(--border);">Editar Información de la Cuenta</h3>

            @if (ViewBag.Error != null)
            {
                <div style="background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.3); border-radius: var(--radius-md); padding: 0.75rem 1rem; color: var(--danger); font-size: 0.85rem; margin-bottom: 1.5rem;">
                    @ViewBag.Error
                </div>
            }
            @if (ViewBag.Success != null)
            {
                <div style="background: rgba(16, 185, 129, 0.1); border: 1px solid rgba(16, 185, 129, 0.3); border-radius: var(--radius-md); padding: 0.75rem 1rem; color: var(--accent); font-size: 0.85rem; margin-bottom: 1.5rem;">
                    @ViewBag.Success
                </div>
            }

            <form method="post" action="@Url.Action("Profile", "Home")">
                <div class="form-row">
                    <div class="form-group">
                        <label for="nombre" class="form-label">Nombre:</label>
                        <input type="text" id="nombre" name="nombre" class="form-control" value="@nombre" required />
                    </div>
                    <div class="form-group">
                        <label for="apellido" class="form-label">Apellido:</label>
                        <input type="text" id="apellido" name="apellido" class="form-control" value="@apellido" required />
                    </div>
                </div>

                <div class="form-group">
                    <label for="correo" class="form-label">Correo Electrónico:</label>
                    <input type="email" id="correo" name="correo" class="form-control" value="@userEmail" required />
                </div>

                <h4 style="margin: 2rem 0 1rem 0; padding-bottom: 0.5rem; border-bottom: 1px solid var(--border); font-size: 1.1rem; color: #fff;">Cambiar Contraseña</h4>

                <div class="form-row">
                    <div class="form-group">
                        <label for="nuevaClave" class="form-label">Nueva Contraseña:</label>
                        <input type="password" id="nuevaClave" name="nuevaClave" class="form-control" placeholder="Mínimo 6 caracteres" />
                    </div>
                    <div class="form-group">
                        <label for="confirmarClave" class="form-label">Confirmar Nueva Contraseña:</label>
                        <input type="password" id="confirmarClave" name="confirmarClave" class="form-control" placeholder="••••••••" />
                    </div>
                </div>

                <div style="display: flex; justify-content: flex-end; gap: 1rem; margin-top: 1.5rem;">
                    <a asp-controller="Operator" asp-action="Dashboard" class="btn btn-secondary">Cancelar</a>
                    <button type="submit" class="btn btn-primary">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path><polyline points="17 21 17 13 7 13 7 21"></polyline><polyline points="7 3 7 8 15 8"></polyline></svg>
                        Guardar Cambios
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
