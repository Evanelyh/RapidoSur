@model RapidoSur.Models.ReporteViewModel
@{
    ViewData["Title"] = "Reportes de Desempeño Logístico";
}

<div class="header-navbar no-print">
    <div>
        <h1 class="page-title">Reportes de Desempeño Logístico</h1>
        <p class="page-subtitle">Generación de reportes operativos, incidencias registradas y auditoría de flota.</p>
    </div>
    @if (Model.Resultados != null && Model.Resultados.Count > 0)
    {
        <button class="btn btn-secondary" onclick="window.print()">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"></polyline><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"></path><rect x="6" y="14" width="12" height="8"></rect></svg>
            Imprimir / PDF
        </button>
    }
</div>

<!-- FORMULARIO DE FILTROS DE AUDITORÍA (Ocultar al imprimir) -->
<div class="glass-card no-print" style="margin-bottom: 2rem; padding: 1.5rem;">
    <form method="post" action="@Url.Action("Reports", "Operator")">
        <div class="form-row" style="align-items: flex-end;">
            <div class="form-group" style="margin-bottom: 0;">
                <label for="tipoReporte" class="form-label">Tipo de Reporte:</label>
                <select id="tipoReporte" name="tipoReporte" class="form-control">
                    <option value="Entregas" selected="@(Model.TipoReporte == "Entregas" ? "selected" : null)">Entregas Completadas</option>
                    <option value="Incidencias" selected="@(Model.TipoReporte == "Incidencias" ? "selected" : null)">Incidencias Registradas</option>
                    <option value="Flota" selected="@(Model.TipoReporte == "Flota" ? "selected" : null)">Uso e Historial de Flota</option>
                    <option value="Pedidos" selected="@(Model.TipoReporte == "Pedidos" ? "selected" : null)">Auditoría de Pedidos Totales</option>
                </select>
            </div>

            <div class="form-group" style="margin-bottom: 0;">
                <label for="fechaInicio" class="form-label">Fecha de Inicio:</label>
                <input type="date" id="fechaInicio" name="fechaInicio" class="form-control" value="@Model.FechaInicio.ToString("yyyy-MM-dd")" required />
            </div>

            <div class="form-group" style="margin-bottom: 0;">
                <label for="fechaFin" class="form-label">Fecha de Fin:</label>
                <input type="date" id="fechaFin" name="fechaFin" class="form-control" value="@Model.FechaFin.ToString("yyyy-MM-dd")" required />
            </div>

            <button type="submit" class="btn btn-primary" style="height: 46px;">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                Generar Reporte
            </button>
        </div>
    </form>
</div>

<!-- VISTA DE REPORTE PARA IMPRESIÓN (Cabecera formal académica) -->
<div class="print-header" style="display: none; border-bottom: 3px double #000; padding-bottom: 1rem; margin-bottom: 2rem;">
    <div style="text-align: center;">
        <h2 style="color: #000; font-size: 1.5rem; text-transform: uppercase;">Rápido Sur S.R.L. - Sistema Logístico</h2>
        <h3 style="color: #333; font-size: 1.25rem; margin-top: 0.25rem;">Reporte Logístico de Desempeño Operativo</h3>
        <p style="color: #555; font-size: 0.9rem; margin-top: 0.25rem;">
            <strong>Tipo de Auditoría:</strong> @Model.TipoReporte | 
            <strong>Período:</strong> @Model.FechaInicio.ToString("dd/MM/yyyy") al @Model.FechaFin.ToString("dd/MM/yyyy")
        </p>
    </div>
</div>

<!-- TABLA DE RESULTADOS DINÁMICOS -->
<div class="glass-card print-card">
    <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border); padding-bottom: 1rem; margin-bottom: 1.5rem;">
        <h3 style="font-size: 1.25rem; color: #fff;" class="print-text-dark">
            Resultados del Reporte: @Model.TipoReporte
        </h3>
        <span class="badge asignado no-print">@Model.TotalRegistros Registros</span>
    </div>

    @if (Model.Resultados != null && Model.Resultados.Count > 0)
    {
        <div class="table-responsive">
            <table class="premium-table print-table">
                <thead>
                    <tr>
                        @foreach (var key in Model.Resultados[0].Keys)
                        {
                            <th>@key</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Model.Resultados)
                    {
                        <tr>
                            @foreach (var val in row.Values)
                            {
                                <td>
                                    @if (val is DateTime dt)
                                    {
                                        @dt.ToString("dd/MM/yyyy hh:mm tt")
                                    }
                                    else if (val is decimal dec)
                                    {
                                        @dec.ToString("F2")
                                    }
                                    else if (val == DBNull.Value || val == null)
                                    {
                                        <span style="color: var(--text-muted);">N/D</span>
                                    }
                                    else if (val.ToString() == "Entregado" || val.ToString() == "Disponible")
                                    {
                                        <span class="badge entregado">@val</span>
                                    }
                                    else if (val.ToString() == "En Ruta")
                                    {
                                        <span class="badge en-ruta">@val</span>
                                    }
                                    else if (val.ToString() == "Asignado")
                                    {
                                        <span class="badge asignado">@val</span>
                                    }
                                    else if (val.ToString() == "Con Incidencia" || val.ToString() == "Mantenimiento")
                                    {
                                        <span class="badge con-incidencia">@val</span>
                                    }
                                    else
                                    {
                                        @val.ToString()
                                    }
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div style="text-align: center; color: var(--text-muted); padding: 4rem;">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-bottom: 1rem;"><circle cx="12" cy="12" r="10"></circle><line x1="8" y1="12" x2="16" y2="12"></line></svg>
            <p>No se encontraron datos registrados para el tipo de reporte y rango de fechas seleccionados.</p>
        </div>
    }
</div>

<!-- ESTILOS DE IMPRESIÓN PERSONALIZADOS -->
<style>
    @@media print {
        body {
            background: #fff !important;
            color: #000 !important;
        }
        
        .no-print {
            display: none !important;
        }
        
        .sidebar {
            display: none !important;
        }
        
        .main-content {
            margin-left: 0 !important;
            padding: 0 !important;
        }
        
        .print-header {
            display: block !important;
        }
        
        .print-card {
            background: #fff !important;
            box-shadow: none !important;
            border: none !important;
            padding: 0 !important;
        }
        
        .print-text-dark {
            color: #000 !important;
        }
        
        .print-table th {
            background: #f3f4f6 !important;
            color: #000 !important;
            border-bottom: 2px solid #000 !important;
            font-size: 0.8rem !important;
        }
        
        .print-table td {
            color: #000 !important;
            border-bottom: 1px solid #ddd !important;
            font-size: 0.8rem !important;
            background: none !important;
        }
        
        .badge {
            background: none !important;
            border: none !important;
            padding: 0 !important;
            color: #000 !important;
            font-weight: 700 !important;
        }
    }
</style>
