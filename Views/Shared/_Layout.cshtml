@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
@{
    var session = HttpContextAccessor.HttpContext?.Session;
    var isLoggedIn = session?.GetString("IsLoggedIn") == "true";
    var userType = session?.GetString("UserType");
    var userName = session?.GetString("UserName") ?? "Usuario";
    var userRole = session?.GetString("UserRole") ?? "Invitado";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Rápido Sur S.R.L.</title>
    
    <!-- Hoja de estilos premium global -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <!-- Mostrar notificaciones del sistema tipo Toast -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="toast-alert toast-success" id="toastAlert">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
            <span>@TempData["SuccessMessage"]</span>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="toast-alert toast-error" id="toastAlert">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="15" y1="9" x2="9" y2="15"></line><line x1="9" y1="9" x2="15" y2="15"></line></svg>
            <span>@TempData["ErrorMessage"]</span>
        </div>
    }

    @if (isLoggedIn)
    {
        <div class="app-container">
            <!-- MENÚ LATERAL (SIDEBAR) ADAPTABLE SEGÚN ROL -->
            <aside class="sidebar">
                <div class="sidebar-logo">
                    <!-- Icono SVG Logístico Premium -->
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--primary);"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
                    <span>Rápido Sur</span>
                </div>

                <ul class="sidebar-menu">
                    @if (userType == "Operador")
                    {
                        <li class="sidebar-item @(ViewContext.RouteData.Values["Action"]?.ToString() == "Dashboard" ? "active" : "")">
                            <a asp-controller="Operator" asp-action="Dashboard">
                                <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="9" rx="1"></rect><rect x="14" y="3" width="7" height="5" rx="1"></rect><rect x="14" y="12" width="7" height="9" rx="1"></rect><rect x="3" y="16" width="7" height="5" rx="1"></rect></svg>
                                Panel Principal
                            </a>
                        </li>
                        <li class="sidebar-item @(ViewContext.RouteData.Values["Action"]?.ToString() == "NewOrder" ? "active" : "")">
                            <a asp-controller="Operator" asp-action="NewOrder">
                                <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"></path></svg>
                                Registrar Pedido
                            </a>
                        </li>
                        <li class="sidebar-item @(ViewContext.RouteData.Values["Action"]?.ToString() == "AssignVehicle" ? "active" : "")">
                            <a asp-controller="Operator" asp-action="AssignVehicle">
                                <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 17a2 2 0 11-4 0 2 2 0 014 0zM19 17a2 2 0 11-4 0 2 2 0 014 0z"></path><path d="M13 9H4a2 2 0 00-2 2v5a2 2 0 002 2h1a2 2 0 002-2v-3a2 2 0 012-2h7a2 2 0 012 2v3a2 2 0 002 2h1a2 2 0 002-2v-5a2 2 0 00-2-2h-3"></path><path d="M13 5h4l3 3v4"></path></svg>
                                Despachar Flota
                            </a>
                        </li>
                        @if (userRole == "Administrador")
                        {
                            <li class="sidebar-item @(ViewContext.RouteData.Values["Action"]?.ToString() == "Reports" ? "active" : "")">
                                <a asp-controller="Operator" asp-action="Reports">
                                    <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 002 2h2a2 2 0 002-2"></path></svg>
                                    Reportes ADS
                                </a>
                            </li>
                        }
                    }
                    else if (userType == "Conductor")
                    {
                        <li class="sidebar-item @(ViewContext.RouteData.Values["Action"]?.ToString() == "Dashboard" ? "active" : "")">
                            <a asp-controller="Driver" asp-action="Dashboard">
                                <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 17a2 2 0 11-4 0 2 2 0 014 0zM19 17a2 2 0 11-4 0 2 2 0 014 0z"></path><path d="M13 9H4a2 2 0 00-2 2v5a2 2 0 002 2h1a2 2 0 002-2v-3a2 2 0 012-2h7a2 2 0 012 2v3a2 2 0 002 2h1a2 2 0 002-2v-5a2 2 0 00-2-2h-3"></path></svg>
                                Mis Envíos
                            </a>
                        </li>
                    }

                    <li class="sidebar-item @(ViewContext.RouteData.Values["Action"]?.ToString() == "Profile" ? "active" : "")">
                        <a asp-controller="Home" asp-action="Profile">
                            <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                            Mi Perfil
                        </a>
                    </li>
                </ul>

                <div class="sidebar-footer">
                    <div class="user-badge">
                        <div class="user-avatar">
                            @userName.Substring(0, 1).ToUpper()
                        </div>
                        <div class="user-info">
                            <span class="user-name">@userName</span>
                            <span class="user-role">@userRole</span>
                        </div>
                    </div>
                    <a asp-controller="Home" asp-action="Logout" class="btn btn-danger" style="padding: 0.6rem 1rem; width: 100%;">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
                        Cerrar Sesión
                    </a>
                </div>
            </aside>

            <!-- CONTENIDO DE LA PÁGINA -->
            <main class="main-content">
                @RenderBody()
            </main>
        </div>
    }
    else
    {
        <!-- MENÚ DE INVITADO (PORTAL PÚBLICO) -->
        <header style="background: rgba(15, 23, 42, 0.8); backdrop-filter: blur(12px); border-bottom: 1px solid var(--border); padding: 1.25rem 3rem; display: flex; justify-content: space-between; align-items: center; position: sticky; top: 0; z-index: 1000;">
            <div style="display: flex; align-items: center; gap: 0.75rem; cursor: pointer;" onclick="location.href='@Url.Action("Index", "Home")'">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--primary);"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
                <span style="font-family: var(--font-heading); font-size: 1.5rem; font-weight: 800; background: linear-gradient(135deg, #fff 0%, var(--primary) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Rápido Sur</span>
            </div>
            <nav style="display: flex; align-items: center; gap: 2rem;">
                <a asp-controller="Home" asp-action="Index" style="color: #fff; font-weight: 500; transition: var(--transition);" onmouseover="this.style.color='var(--primary)'" onmouseout="this.style.color='#fff'">Portal Cliente</a>
                <a asp-controller="Home" asp-action="Login" class="btn btn-primary" style="padding: 0.6rem 1.5rem; font-size: 0.9rem;">Acceso Personal</a>
            </nav>
        </header>

        <div style="min-height: calc(100vh - 80px); display: flex; flex-direction: column;">
            @RenderBody()
            <footer style="margin-top: auto; border-top: 1px solid var(--border); padding: 2rem; text-align: center; color: var(--text-muted); font-size: 0.85rem; background: rgba(10, 15, 30, 0.4);">
                &copy; 2026 - Rápido Sur S.R.L. | Universidad Don Bosco - Análisis y Diseño de Sistemas
            </footer>
        </div>
    }

    <!-- SCRIPT DE AUTO-OCULTADO DE NOTIFICACIÓN DE NOTAS -->
    <script>
        const toast = document.getElementById('toastAlert');
        if (toast) {
            setTimeout(() => {
                toast.style.opacity = '0';
                toast.style.transform = 'translateY(-20px)';
                toast.style.transition = 'all 0.5s ease';
                setTimeout(() => toast.remove(), 500);
            }, 4000);
        }
    </script>

</body>
</html>
